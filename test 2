port: 7890
socks-port: 7891
allow-lan: true
mode: global
log-level: info

tun:
  enable: true
  stack: system
  auto-route: true
  dns-hijack:
    - 0.0.0.0:53
  mtu: 1500

dns:
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  default-nameserver:
    - 8.8.8.8
    - 1.1.1.1
  nameserver:
    - https://dns.google/dns-query
    - https://doh.pub/dns-query

proxies:
  - name: "opensocks-us1"
    type: ss
    server: us1.opensocks.site
    port: 8388
    cipher: chacha20-ietf-poly1305
    password: NDc3ZTg3
    udp: true

proxy-groups:
  - name: "PROXY"
    type: select
    proxies:
      - opensocks-us1
      - DIRECT

rules:
  - MATCH,PROXY